# Server-only (route handler; never reach the client bundle)
# Resend dashboard -> API Keys. Without it the form returns 503 and the client
# shows the direct-email fallback — deploys stay honest before setup.
RESEND_API_KEY=
# Recipient; defaults to site.contact.email in code when unset.
CONTACT_TO_EMAIL=
# Sender; defaults to "Portfolio <onboarding@resend.dev>" (Resend testing sender:
# may deliver ONLY to the Resend account owner's address until a domain is verified).
RESEND_FROM=

# Client-side (NEXT_PUBLIC_* are BUILD-TIME inlined — adding/changing a value in
# Vercel requires a redeploy to take effect).
# PostHog project token (public, write-only by design). Absent -> analytics no-op.
NEXT_PUBLIC_POSTHOG_KEY=
# Canonical origin for sitemap/robots; defaults to the vercel.app URL in code.
NEXT_PUBLIC_SITE_URL=

# NEXT_PUBLIC_POSTHOG_HOST is intentionally absent — events go through the
# first-party /relay/i/v0/e/ rewrite (next.config.ts), not a direct host.
